<% layout("/layouts/boilerPlate") %>
<!-- <%= success %> -->

    <h3>All listings</h3>
    <!-- <br>
     <form method="get"  action="/listings/new">
        <button>Create new Destination</button>
    </form> -->
    <div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1">
            <% for(let list of allListings ){%>
                <a href="/listings/<%= list._id %>" class="listing-link">
                <div class="listing-card col card" >
                <img
                 src=<%= list.image %>
                class="card-img-top"
                 alt="listing_image"
                 style="height: 20rem" />
                 <div class="card-img-overlay"></div>
                <div class="card-body">
                  <p class="card-text"><b><%= list.title  %></b>
                  <br>
                  &#8377; <%= list.price.toLocaleString("en-IN")  %>/night
                  <br>
                  </p>
                </div>
            </div>
        </a>
        <% } %>
    </div>


